{
  "mcpServers": {
    "memorix": {
      "command": "memorix",
      "args": [
        "serve"
      ],
      "disabled": false,
      "autoApprove": [
        "*"
      ]
    },
    "gitnexus": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "gitnexus",
        "mcp"
      ],
      "disabled": false,
      "autoApprove": [
        "*"
      ]
    },
    "context7": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "disabled": false,
      "autoApprove": [
        "*"
      ]
    }
  }
}
